# Backend Environment Variables (copy to .env in backend/ directory)

# Server Configuration
PORT=3100

# Database Configuration
# For Local Development (SQLite):
# DATABASE_URL=file:./dev.db

# For Render Production (PostgreSQL):
# Get this from Render dashboard when you create a PostgreSQL database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT Token Secret (use a long, random string - change this in production!)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_12345

# CORS Configuration - set to your frontend URL
# Local Development:
CORS_ORIGIN=http://localhost:3100

# Production (Render + Netlify):
# CORS_ORIGIN=https://your-netlify-domain.netlify.app

# Node Environment
NODE_ENV=development
