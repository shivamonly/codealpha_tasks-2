{
  "services": [
    {
      "type": "web",
      "name": "core-backend",
      "runtime": "node",
      "plan": "free",
      "buildCommand": "cd backend && npm install && npm run db:push",
      "startCommand": "cd backend && npm start",
      "envVars": [
        {
          "key": "NODE_ENV",
          "value": "production"
        },
        {
          "key": "PORT",
          "value": "3100"
        },
        {
          "key": "JWT_SECRET",
          "sync": false
        },
        {
          "key": "CORS_ORIGIN",
          "sync": false
        },
        {
          "key": "DATABASE_URL",
          "fromDatabase": {
            "name": "core-postgres",
            "property": "connectionString"
          }
        }
      ]
    },
    {
      "type": "postgres",
      "name": "core-postgres",
      "plan": "free",
      "ipAllowList": []
    }
  ]
}
